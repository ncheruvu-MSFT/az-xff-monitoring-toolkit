        <mxCell id="title1" value="&lt;b&gt;Proxy (VIP) → Application Gateway → App Service — XFF Header Flow&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;fontSize=16;" vertex="1" parent="1">

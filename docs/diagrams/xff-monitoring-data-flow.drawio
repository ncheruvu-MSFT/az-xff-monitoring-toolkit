          <mxGeometry x="60" y="295" width="260" height="130" as="geometry"/>
        </mxCell>
        <mxCell id="table1title" value="&lt;b&gt;AzureDiagnostics&lt;/b&gt; (App Gateway Logs)" style="text;html=1;fontSize=11;fontColor=#333;" vertex="1" parent="1">
          <mxGeometry x="70" y="300" width="240" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="table1field" value="&lt;b&gt;clientIP_s&lt;/b&gt; = &lt;font color=&quot;#D32F2F&quot;&gt;&lt;b&gt;Proxy VIP IP&lt;/b&gt;&lt;/font&gt; ⚠️" style="text;html=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="80" y="325" width="220" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="table1note" value="TCP peer only — shows who&lt;br&gt;connected to App Gateway,&lt;br&gt;NOT the real end user" style="text;html=1;fontSize=9;fontColor=#999;" vertex="1" parent="1">
          <mxGeometry x="80" y="350" width="200" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="table1status" value="&lt;font color=&quot;#D32F2F&quot;&gt;&lt;b&gt;❌ Real client IP NOT available&lt;/b&gt;&lt;/font&gt;" style="text;html=1;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="80" y="395" width="220" height="20" as="geometry"/>
        </mxCell>

        <!-- Table 2: AppServiceHTTPLogs -->
        <mxCell id="table2bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#D32F2F;arcSize=8;shadow=0;" vertex="1" parent="1">
          <mxGeometry x="360" y="295" width="260" height="130" as="geometry"/>
        </mxCell>
        <mxCell id="table2title" value="&lt;b&gt;AppServiceHTTPLogs&lt;/b&gt; (App Service)" style="text;html=1;fontSize=11;fontColor=#333;" vertex="1" parent="1">
          <mxGeometry x="370" y="300" width="240" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="table2field" value="&lt;b&gt;CIp&lt;/b&gt; = &lt;font color=&quot;#D32F2F&quot;&gt;&lt;b&gt;App Gateway IP&lt;/b&gt;&lt;/font&gt; ⚠️" style="text;html=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="380" y="325" width="220" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="table2note" value="TCP peer only — shows who&lt;br&gt;connected to App Service,&lt;br&gt;NOT the real end user" style="text;html=1;fontSize=9;fontColor=#999;" vertex="1" parent="1">
          <mxGeometry x="380" y="350" width="200" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="table2status" value="&lt;font color=&quot;#D32F2F&quot;&gt;&lt;b&gt;❌ Real client IP NOT available&lt;/b&gt;&lt;/font&gt;" style="text;html=1;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="380" y="395" width="220" height="20" as="geometry"/>
        </mxCell>

        <!-- Table 3: Application Insights (THE SOLUTION) -->
        <mxCell id="table3bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#2E7D32;arcSize=8;shadow=1;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="660" y="295" width="280" height="130" as="geometry"/>
        </mxCell>
        <mxCell id="table3title" value="&lt;b&gt;Application Insights&lt;/b&gt; (requests table)" style="text;html=1;fontSize=11;fontColor=#333;" vertex="1" parent="1">
          <mxGeometry x="670" y="300" width="260" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="table3field1" value="&lt;b&gt;customDimensions[&amp;quot;X-Forwarded-For&amp;quot;]&lt;/b&gt;" style="text;html=1;fontSize=10;fontColor=#2E7D32;" vertex="1" parent="1">
          <mxGeometry x="680" y="325" width="250" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="table3field2" value="= &lt;font color=&quot;#2E7D32&quot;&gt;&lt;b&gt;203.0.113.50 (Real Client!)&lt;/b&gt;&lt;/font&gt; ✅" style="text;html=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="680" y="345" width="250" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="table3note" value="Captured by ForwardedHeaders&lt;br&gt;middleware + XffTelemetry&lt;br&gt;Initializer in app code" style="text;html=1;fontSize=9;fontColor=#999;" vertex="1" parent="1">
          <mxGeometry x="680" y="370" width="200" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="table3status" value="&lt;font color=&quot;#2E7D32&quot;&gt;&lt;b&gt;✅ Real client IP AVAILABLE&lt;/b&gt;&lt;/font&gt;" style="text;html=1;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="680" y="395" width="220" height="20" as="geometry"/>
        </mxCell>

        <!-- Diagnostic Settings arrows -->
        <mxCell id="diag1" value="Diagnostic&lt;br&gt;Settings" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#0078D4;strokeWidth=1;dashed=1;fontSize=8;fontColor=#0078D4;verticalAlign=top;labelBackgroundColor=none;" edge="1" source="appgw" target="table1bg" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="diag2" value="Diagnostic&lt;br&gt;Settings" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#7FBA00;strokeWidth=1;dashed=1;fontSize=8;fontColor=#7FBA00;verticalAlign=top;labelBackgroundColor=none;" edge="1" source="appsvc" target="table2bg" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="diag3" value="App Insights&lt;br&gt;SDK" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#9C27B0;strokeWidth=2;dashed=0;fontSize=8;fontColor=#9C27B0;verticalAlign=top;labelBackgroundColor=none;" edge="1" source="appinsights_icon" target="table3bg" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ═══ BOTTOM: Required Configuration ═══ -->
        <mxCell id="reqBg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#9C27B0;arcSize=5;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="600" width="920" height="170" as="geometry"/>
        </mxCell>
        <mxCell id="reqLabel" value="&lt;b&gt;Required Configuration for Real Client IP&lt;/b&gt;" style="text;html=1;fontSize=13;fontColor=#6A1B9A;" vertex="1" parent="1">
          <mxGeometry x="320" y="605" width="330" height="25" as="geometry"/>
        </mxCell>

        <!-- Step 1 -->
        <mxCell id="step1" value="&lt;b&gt;① Proxy&lt;/b&gt;&lt;br&gt;&lt;br&gt;Set &lt;font color=&quot;#E65100&quot;&gt;X-Forwarded-For&lt;/font&gt;&lt;br&gt;header on outbound&lt;br&gt;requests&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#666&quot;&gt;Nginx: proxy_set_header&lt;br&gt;X-Forwarded-For&lt;br&gt;$proxy_add_x_forwarded_for&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#F25022;fontSize=9;shadow=0;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="60" y="640" width="180" height="120" as="geometry"/>
        </mxCell>

        <!-- Step 2 -->
        <mxCell id="step2" value="&lt;b&gt;② App Gateway&lt;/b&gt;&lt;br&gt;&lt;br&gt;Deploy &lt;font color=&quot;#1565C0&quot;&gt;Rewrite Rule&lt;/font&gt;&lt;br&gt;&lt;br&gt;Header: X-Forwarded-For&lt;br&gt;Value: &lt;font color=&quot;#1565C0&quot;&gt;{var_add_x_forwarded&lt;br&gt;_for_proxy}&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#666&quot;&gt;Strips non-standard :port&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#0078D4;fontSize=9;shadow=0;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="270" y="640" width="180" height="120" as="geometry"/>
        </mxCell>

        <!-- Step 3 -->
        <mxCell id="step3" value="&lt;b&gt;③ App Service&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#33691E&quot;&gt;ForwardedHeaders&lt;br&gt;Middleware&lt;/font&gt; (FIRST!)&lt;br&gt;&lt;br&gt;Trust KnownNetworks&lt;br&gt;ForwardLimit = null&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#666&quot;&gt;.NET / Python / Java&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#7FBA00;fontSize=9;shadow=0;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="480" y="640" width="180" height="120" as="geometry"/>
        </mxCell>

        <!-- Step 4 -->
        <mxCell id="step4" value="&lt;b&gt;④ Telemetry Initializer&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#6A1B9A&quot;&gt;XffTelemetryInitializer&lt;/font&gt;&lt;br&gt;&lt;br&gt;Captures XFF header&lt;br&gt;into App Insights&lt;br&gt;customDimensions&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#666&quot;&gt;Query via KQL&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#9C27B0;fontSize=9;shadow=0;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="690" y="640" width="180" height="120" as="geometry"/>
        </mxCell>

        <!-- Step arrows -->
        <mxCell id="sa1" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#666;strokeWidth=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="step1" target="step2" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="sa2" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#666;strokeWidth=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="step2" target="step3" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="sa3" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#666;strokeWidth=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="step3" target="step4" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Legend -->
        <mxCell id="legend" value="&lt;font color=&quot;#D32F2F&quot;&gt;⚠️ Red border&lt;/font&gt; = TCP peer IP only (not real client)      &lt;font color=&quot;#2E7D32&quot;&gt;✅ Green border&lt;/font&gt; = Real client IP available (via middleware)" style="text;html=1;fontSize=10;fontColor=#666;align=center;" vertex="1" parent="1">
          <mxGeometry x="150" y="455" width="680" height="20" as="geometry"/>
        </mxCell>

        <!-- Retention box -->

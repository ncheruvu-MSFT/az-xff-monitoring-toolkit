          <mxGeometry x="60" y="490" width="880" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="retTitle" value="&lt;b&gt;📦 Log Retention &amp; Cost&lt;/b&gt;" style="text;html=1;fontSize=11;fontColor=#F57F17;" vertex="1" parent="1">
          <mxGeometry x="400" y="495" width="180" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="ret1" value="&lt;b&gt;Interactive (hot):&lt;/b&gt; 30 days default → up to 730 days&lt;br&gt;Cost: Free for first 31 days, then $0.10/GB/month" style="text;html=1;fontSize=9;fontColor=#333;" vertex="1" parent="1">
          <mxGeometry x="80" y="520" width="270" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="ret2" value="&lt;b&gt;Archive (cold):&lt;/b&gt; Up to 12 years total&lt;br&gt;Cost: $0.02/GB/month" style="text;html=1;fontSize=9;fontColor=#333;" vertex="1" parent="1">
          <mxGeometry x="370" y="520" width="200" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="ret3" value="&lt;b&gt;Ingestion:&lt;/b&gt; $2.76/GB (Analytics) or $0.65/GB (Basic)&lt;br&gt;Free allowance: 5 GB/day per billing account" style="text;html=1;fontSize=9;fontColor=#333;" vertex="1" parent="1">
          <mxGeometry x="600" y="520" width="300" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="ret4" value="&lt;b&gt;💡 Tip:&lt;/b&gt; Export to Azure Storage ($0.018/GB/month) for cheapest long-term retention" style="text;html=1;fontSize=9;fontColor=#F57F17;" vertex="1" parent="1">
          <mxGeometry x="300" y="555" width="400" height="20" as="geometry"/>
        </mxCell>

